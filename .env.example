# Groq API Key — get yours at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# OpenAI (not required — using Groq + FastEmbed instead)
OPENAI_API_KEY=

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base

# Embeddings — FastEmbed runs locally, no API key needed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LLM — Groq provider
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Ollama (not needed when using Groq)
OLLAMA_BASE_URL=http://localhost:11434

# App Bearer token — use this key in Authorization header when calling the API
API_KEY=rag-secret-key-2024

# Logging
LOG_LEVEL=INFO
